# Required for DB + S3 
AWS_S3_BUCKET=
AWS_REGION=ca-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# DB:
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGHOST=

# Pipeline constants
COSINE_THRESHOLD=0.98
DINOV2_MODEL=dinov2_vitb14
BATCH_SIZE=32

# Optional Roboflow preprocessing (default on)
USE_BIN_MASK_FOR_EMBEDDING=true
ROBOFLOW_MODEL_ID=
ROBOFLOW_API_KEY=
ROBOFLOW_BIN_CLASS=tote-bin
ROBOFLOW_BG=0
ROBOFLOW_PAD=10

# Runtime tuning
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
